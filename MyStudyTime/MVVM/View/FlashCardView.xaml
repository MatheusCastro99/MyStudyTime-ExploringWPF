<UserControl x:Class="MyStudyTime.MVVM.View.FlashCardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Background="#f5f5f5">
            <StackPanel Margin="20">
                <TextBlock Text="Flash Cards" FontSize="24" FontWeight="Bold" Foreground="#2d2d2d"/>
                <TextBlock Text="{Binding SubjectName}" FontSize="14" Foreground="#666" Margin="0,5"/>
                
                <TextBlock Text="Cards:" FontSize="14" FontWeight="Bold" Margin="0,15,0,5"/>
                <ListBox ItemsSource="{Binding FlashCards}" Height="250" Background="White" BorderBrush="#ddd">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#eee" BorderThickness="0,0,0,1">
                                <Grid Margin="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Question}" FontWeight="Bold" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Answer}" Foreground="#666" Margin="0,5,0,0" FontSize="12"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Command="{Binding DataContext.RemoveFlashCardCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                            CommandParameter="{Binding .}" 
                                            Background="#e74c3c" Foreground="White" Margin="10,0,0,0">Remove</Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                
                <Border Background="White" BorderBrush="#ddd" BorderThickness="1" Padding="15" Margin="0,15,0,0">
                    <StackPanel>
                        <TextBlock Text="Add New Flash Card" FontWeight="Bold" Margin="0,0,0,10"/>
                        <StackPanel>
                            <TextBlock Text="Question:" FontSize="12" Foreground="#333"/>
                            <TextBox Text="{Binding NewQuestion, UpdateSourceTrigger=PropertyChanged}" 
                                     Padding="10" Height="50" TextWrapping="Wrap" AcceptsReturn="True"/>

                            <TextBlock Text="Answer:" FontSize="12" Foreground="#333" Margin="0,10,0,0"/>
                            <TextBox Text="{Binding NewAnswer, UpdateSourceTrigger=PropertyChanged}" 
                                     Padding="10" Height="50" TextWrapping="Wrap" AcceptsReturn="True"/>

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                    <TextBlock Text="Difficulty:" FontSize="12" Foreground="#333" Margin="0,0,0,5"/>
                                    <ComboBox SelectedItem="{Binding NewDifficulty}">
                                        <ComboBoxItem>Easy</ComboBoxItem>
                                        <ComboBoxItem>Medium</ComboBoxItem>
                                        <ComboBoxItem>Hard</ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                    <TextBlock Text="Tags (comma separated):" FontSize="12" Foreground="#333" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding NewTags, UpdateSourceTrigger=PropertyChanged}" Padding="10"/>
                                </StackPanel>
                            </Grid>

                            <Button Command="{Binding AddFlashCardCommand}" 
                                    Background="#27ae60" Foreground="White" Padding="10,8" Margin="0,10,0,0">
                                Add Flash Card
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <Button Command="{Binding StartReviewCommand}" 
                        Background="#3498db" Foreground="White" Margin="0,10,0,0" Padding="10">
                    Start Review
                </Button>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
