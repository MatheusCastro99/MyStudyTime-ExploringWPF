<Application x:Class="MyStudyTime.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MyStudyTime"
             xmlns:viewModel="clr-namespace:MyStudyTime.MVVM.ViewModel"
             xmlns:view="clr-namespace:MyStudyTime.MVVM.View"
             xmlns:core="clr-namespace:MyStudyTime.Core"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Theme/MenuButtonTheme.xaml"/>
                <ResourceDictionary Source="Theme/SearchBoxTheme.xaml"/>
                <ResourceDictionary Source="Theme/CloseMinMaxButtonTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <core:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <core:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
            <core:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <core:BoolToColorConverter x:Key="BoolToColorConverter"/>

            <!-- Data Templates -->
            <DataTemplate DataType="{x:Type viewModel:HomeViewModel}">
                <view:HomeView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type viewModel:SubjectViewModel}">
                <view:SubjectView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type viewModel:FlashCardViewModel}">
                <view:FlashCardView/>
            </DataTemplate>

            <FontFamily x:Key="FontAwesomeSolid">/Fonts/#Font Awesome 6 Free Solid</FontFamily>

        </ResourceDictionary>
    </Application.Resources>
</Application>
